#!/usr/bin/env bash
# check-token-discipline [skills-root]
#
# Conformance checker for the token-discipline "Dispatch authoring" rules
# (specs/workflow-token-efficiency/SPEC.md, R6). Exits 0 iff every file in the
# in-scope list passes three paragraph-level checks, and exits 1 with a
# per-file, per-check report otherwise:
#
#   [dispatch]  every dispatch paragraph carries a tier token (in itself or an
#               adjacent paragraph)
#   [budget]    the file states an output budget at least once
#   [loop]      every iterative re-dispatch names a cycle bound (in itself or
#               an adjacent paragraph)
#
# The checks operate on blank-line-separated paragraphs (YAML frontmatter and
# `|`-leading table rows skipped, wrapped lines joined) so verb/noun pairs
# split across wrapped lines are seen together. The prose here states intent;
# tests/test_check_token_discipline.sh is the contract.
#
# Tests point CHECK_TD_FILES (newline-separated literal paths) at fixture files
# so they never touch the real tree; unset, the checker walks the in-scope list
# under [skills-root] (default: the repo root above this script).
set -u

ROOT="${1:-}"
if [ -z "$ROOT" ]; then
  ROOT="$(cd "$(dirname "$0")/.." && pwd)"
fi

IN_SCOPE='.claude/skills/drain/SKILL.md
.claude/skills/drain/reference.md
.claude/skills/design/SKILL.md
.claude/skills/evals/SKILL.md
.claude/skills/evals/reference.md
.claude/workflows/deep-research.js'

# Build the file list.
FILES=()
if [ -n "${CHECK_TD_FILES:-}" ]; then
  while IFS= read -r f; do
    [ -n "$f" ] && FILES+=("$f")
  done <<EOF
$CHECK_TD_FILES
EOF
else
  while IFS= read -r rel; do
    [ -n "$rel" ] && FILES+=("$ROOT/$rel")
  done <<EOF
$IN_SCOPE
EOF
fi

fail=0
report() { printf '%s\n' "$1"; fail=1; }

# --- regex vocabulary --------------------------------------------------------
# Word edges use (^|[^a-zA-Z]) / ([^a-zA-Z]|$) rather than \b, which BSD grep
# does not support. This also excludes adjectival forms: `dispatchable` never
# matches the dispatch verb (no non-letter follows `dispatch`).
DVERB='(spawn|dispatch|launch)(es|ed|ing|s)?'
DNOUN='(agent|worker|session)s?'
# Verb and noun within ~40 chars of each other, either order.
DADJ="(^|[^a-zA-Z])${DVERB}[^a-zA-Z].{0,40}[^a-zA-Z]${DNOUN}([^a-zA-Z]|\$)"
DADJ_REV="(^|[^a-zA-Z])${DNOUN}[^a-zA-Z].{0,40}[^a-zA-Z]${DVERB}([^a-zA-Z]|\$)"
# A dispatch verb immediately negated -> a pure prohibition, not a dispatch.
DPROHIB="(^|[^a-zA-Z])(no|never|not|cannot|don't)[^a-zA-Z]+${DVERB}([^a-zA-Z]|\$)"

TIER_RE='haiku|session model|opts\.model|effort|tier pin|tier up'

BUDGET_RE='(≤|under|at most|no more than|cap(ped)?)[[:space:]]?.{0,20}(words|tokens|lines)'

# Iterative re-dispatch triggers (lowercased before matching).
LTRIG='(retry|retries|retried|re-dispatch|redispatch|revise|revises|revised|iterate|iterates|iterated|cycle|cycles|cycled|relaunch|relaunches|relaunched|relaunching)'
# A stated bound. A count (digit 1-4, spelled one-four/single, or an ordinal) is
# a bound only in a *counting* context — never a bare stray numeral (wte-07):
#   count [+adj] + cycle noun    "3 cycles", "two rounds", "2-4 cycles",
#                                "single relaunch", "two more times",
#                                "the third pass" (a quantifier may precede the
#                                count via the left word-edge: "up to four rounds")
#   once / twice (as a repeat count, not a temporal clause — see has_bound)
#   a named generation cap       "max-generations", "generations cap"
# The cycle nouns are word-anchored (spelled singular+plural) so a count must
# actually name iterations — "2 timeouts" (time in timeouts), "fewer than 2
# passing" (pass in passing), and "lines 2-4" / "days 2-4" (a range not naming a
# cycle) no longer read as bounds. The count->noun gap is whitespace-only, so a
# glued/hyphenated compound ("onetime", "one-pass") has no word edge and flags;
# a quantifier+count naming a NON-cycle noun ("up to four sources") flags because
# there is no standalone quantifier branch. A generation cap may exceed 4
# (relaunch ceiling). Robust NL bound-detection is not fully regex-achievable
# (two adversarial passes); the wte-08 flag-when-unsure stance
# (specs/workflow-token-efficiency/tasks/08-loop-bound-residuals.md) errs toward
# flagging — a genuinely-capped paragraph states its bound adjacently rather than
# widening these regexes.
# A count: digits 1-4, spelled one-four/single, or an ordinal (first-fourth,
# 1st-4th) — wte-08 added ordinals so "the third pass" reads as a bound.
LNUM='([1-4]|one|two|three|four|single|first|second|third|fourth|1st|2nd|3rd|4th)'
# Cycle nouns, word-anchored (singular+plural). wte-08 added loop(s) and the
# hyphenated re-dispatch forms (only `redispatches` was present).
LNOUN='(times|rounds|cycles|iterations|attempts|retries|reruns|relaunches|revisions|passes|generations|redispatches|re-dispatches|re-dispatch|re-dispatched|loops|tournaments|tries|time|round|cycle|iteration|attempt|retry|rerun|relaunch|revision|pass|generation|redispatch|loop|tournament|try)'
# A single count-adjective may sit between the count and the cycle noun (wte-08)
# — enumerated, not a general gap widening, so "two more times" reads as a bound
# without reopening the "up to four sources" false-negative.
LADJ='(additional|further|more|consecutive)'
# A count [range] immediately followed (after whitespace, optionally one
# count-adjective) by a cycle noun. The count->noun gap is whitespace-only so a
# glued/hyphenated compound (`onetime`, `one-pass`, `twotime`) has no word edge
# and never reads as a bound (wte-08). A bare quantifier+count with NO cycle
# noun ("up to four sources") is deliberately NOT a branch — it must FLAG, per
# the flag-when-unsure stance (wte-08); the quantifier is still accepted here
# via the left word-edge when a cycle noun follows ("up to four rounds").
LBOUND="(^|[^a-z0-9])${LNUM}([^0-9a-z]{0,4}(-|–|to)[^0-9a-z]{0,4}(${LNUM}|[0-9]+))?[[:space:]]{1,4}(${LADJ}[[:space:]]{1,4})?${LNOUN}([^a-z]|$)"
LBOUND="${LBOUND}|(^|[^a-z])(once|twice)([^a-z]|$)"
LBOUND="${LBOUND}|max-generations|generations cap"

# --- helpers -----------------------------------------------------------------
matches() { printf '%s' "$2" | grep -qiE "$1"; }

is_dispatch() { # <paragraph>
  case "$1" in
    *"Task("*|*"agent("*) return 0 ;;
  esac
  matches "$DPROHIB" "$1" && return 1
  matches "$DADJ" "$1" && return 0
  matches "$DADJ_REV" "$1" && return 0
  return 1
}

has_tier() { matches "$TIER_RE" "$1"; }

has_budget() {
  matches "$BUDGET_RE" "$1" && return 0
  printf '%s' "$1" | grep -qiF 'verdict + evidence'
}

is_live_loop() { # <paragraph> — true if a bound-requiring trigger survives
  local lp resid
  lp="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  # Drop excluded occurrences: negated (`no relaunch`), hyphenated
  # (`relaunch-with-evidence`), the reflexive `self-` compound naming a
  # mechanism (`self-relaunch`, wte-08), and benign one-shot state
  # (`relaunch clean`).
  resid="$(printf '%s' "$lp" | sed -E \
    -e "s/(no|never|not|cannot)[^a-z]+${LTRIG}//g" \
    -e "s/${LTRIG}-[a-z]//g" \
    -e "s/self-${LTRIG}//g" \
    -e "s/${LTRIG}[^a-z]+(clean|cleanly|fresh|empty)([^a-z]|$)//g")"
  matches "(^|[^a-z])${LTRIG}" "$resid"
}

has_bound() { # <paragraph>
  # A temporal "once/twice" (a subordinating clause: "once a check goes red")
  # is not a repeat count — strip it before matching so it FLAGS, while a
  # counting "once" ("relaunch once with evidence") still reads as a bound.
  local b
  b="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/(once|twice)[[:space:]]+(a|an|the)([^a-z]|$)/ /g')"
  matches "$LBOUND" "$b"
}

snippet() { printf '%s' "$1" | cut -c1-60; }

# --- per-file checks ---------------------------------------------------------
PARAS=()
load_paragraphs() { # <file> — populate PARAS[] (frontmatter/table rows removed)
  PARAS=()
  local first=1 in_fm=0 para='' line trimmed
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$first" = 1 ]; then
      first=0
      if [ "$line" = '---' ]; then in_fm=1; continue; fi
    fi
    if [ "$in_fm" = 1 ]; then
      [ "$line" = '---' ] && in_fm=0
      continue
    fi
    if [ -z "$line" ]; then
      [ -n "$para" ] && PARAS+=("$para")
      para=''
      continue
    fi
    trimmed="${line#"${line%%[![:space:]]*}"}"
    case "$trimmed" in
      \|*) continue ;;
    esac
    if [ -n "$para" ]; then para="$para $line"; else para="$line"; fi
  done < "$file"
  [ -n "$para" ] && PARAS+=("$para")
}

check_file() { # <file>
  local file="$1"
  if [ ! -f "$file" ]; then
    report "$file: [missing] file not found"
    return
  fi
  load_paragraphs "$file"

  local n=${#PARAS[@]} i prev next

  # Output budget — per file.
  local budget_ok=0
  for ((i=0; i<n; i++)); do
    if has_budget "${PARAS[$i]}"; then budget_ok=1; break; fi
  done
  [ "$budget_ok" = 0 ] && report "$file: [budget] no output-budget statement in file"

  for ((i=0; i<n; i++)); do
    prev=''; next=''
    [ "$i" -gt 0 ] && prev="${PARAS[$((i-1))]}"
    [ "$((i+1))" -lt "$n" ] && next="${PARAS[$((i+1))]}"

    # Dispatch -> tier.
    if is_dispatch "${PARAS[$i]}"; then
      if ! has_tier "${PARAS[$i]}" && ! has_tier "$prev" && ! has_tier "$next"; then
        report "$file: [dispatch] paragraph missing tier token: $(snippet "${PARAS[$i]}")"
      fi
    fi

    # Bounded loops.
    if is_live_loop "${PARAS[$i]}"; then
      if ! has_bound "${PARAS[$i]}" && ! has_bound "$prev" && ! has_bound "$next"; then
        report "$file: [loop] unbounded iterative re-dispatch: $(snippet "${PARAS[$i]}")"
      fi
    fi
  done
}

for file in "${FILES[@]}"; do
  check_file "$file"
done

exit "$fail"
