#!/usr/bin/env bash
# sync-workflows — idempotently symlink toolkit workflow scripts into the user
# workflows dir. Narrow successor to the retired bin/sync-skills (skills are
# plugin-served now; plugins cannot ship workflows, so this one sync is still
# legitimate — SPEC workflow-token-efficiency R5, amended 2026-07-03).
#
# Standard post-`git pull` step:
#   - every FILE under $SYNC_WORKFLOWS_SRC is symlinked into $SYNC_WORKFLOWS_DEST
#   - a symlink whose readlink already equals the target is skipped (not
#     re-linked), so a no-op run reports "linked 0"
#   - entries that are not symlinks into the toolkit (local workflows, foreign
#     symlinks) are never touched; a name collision with one is skipped and
#     reported as "conflict: <name>"
#   - dangling symlinks into the toolkit (workflow removed upstream) are deleted
#   - prints a one-line summary: linked N, removed M, kept K local[, conflicts: ...]
set -euo pipefail

SRC="${SYNC_WORKFLOWS_SRC:-$HOME/claude/.claude/workflows}"
DEST="${SYNC_WORKFLOWS_DEST:-$HOME/.claude/workflows}"

if [ ! -d "$SRC" ]; then
  echo "sync-workflows: source dir not found: $SRC" >&2
  exit 1
fi
mkdir -p "$DEST"

# Normalize to absolute paths for readlink comparison / prefix matching.
SRC="$(cd "$SRC" && pwd)"
DEST="$(cd "$DEST" && pwd)"

linked=0
removed=0
kept=0
conflicts=""

# Pass 1: link every workflow file in the toolkit.
for file in "$SRC"/*; do
  [ -f "$file" ] || continue
  name="$(basename "$file")"
  target="$SRC/$name"
  entry="$DEST/$name"

  if [ -L "$entry" ]; then
    current="$(readlink "$entry")"
    if [ "$current" = "$target" ]; then
      continue # already correct — skip, do not re-link
    fi
    case "$current" in
      "$SRC"/*)
        # Toolkit symlink with a stale/wrong target: fix it.
        ln -sfn "$target" "$entry"
        linked=$((linked + 1))
        ;;
      *)
        # Symlink owned by something else: never touch.
        echo "conflict: $name" >&2
        conflicts="$conflicts $name"
        ;;
    esac
  elif [ -e "$entry" ]; then
    # Non-symlink entry (local workflow file): never touch.
    echo "conflict: $name" >&2
    conflicts="$conflicts $name"
  else
    ln -s "$target" "$entry"
    linked=$((linked + 1))
  fi
done

# Pass 2: remove dangling toolkit symlinks; count everything else as kept local.
for entry in "$DEST"/*; do
  [ -e "$entry" ] || [ -L "$entry" ] || continue # unmatched glob
  if [ -L "$entry" ]; then
    current="$(readlink "$entry")"
    case "$current" in
      "$SRC"/*)
        if [ ! -f "$current" ]; then
          rm "$entry"
          removed=$((removed + 1))
        fi
        ;;
      *)
        kept=$((kept + 1))
        ;;
    esac
  else
    kept=$((kept + 1))
  fi
done

summary="linked $linked, removed $removed, kept $kept local"
if [ -n "$conflicts" ]; then
  summary="$summary, conflicts:$conflicts"
fi
echo "$summary"
