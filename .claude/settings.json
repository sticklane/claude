{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-tool-format.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-tool-protect.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/hooks/plugin-staleness/staleness-check.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/hooks/bd-bootstrap/ensure-bd.sh",
            "timeout": 300,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/hooks/plugin-autorefresh/autorefresh.sh",
            "timeout": 180,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bd-compliance.sh"
          }
        ]
      }
    ]
  },
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(bd *)"
    ]
  },
  "extraKnownMarketplaces": {
    "agentic-toolkit": {
      "source": {
        "source": "github",
        "repo": "sticklane/claude"
      }
    }
  },
  "enabledPlugins": {
    "agentic@agentic-toolkit": true
  }
}
