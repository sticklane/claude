#!/usr/bin/env bash
# Generated by install-gates — staged-file quality gate (SPEC R7).
# Format-check + lint run on the working-tree copies of staged files only;
# whole-project typecheck is included only if measured fast at install time.
# Bypass: git commit --no-verify. Do not edit by hand; re-run install-gates.
@TYPECHECK_MARKER@
set -u

@MATCHES_STACK@

fail() { # fail <stage> <output>
  printf 'pre-commit: %s failed:\n%s\n' "$1" "$2" >&2
  printf 'pre-commit: fix the above or bypass with git commit --no-verify\n' >&2
  exit 1
}

staged=()
while IFS= read -r -d '' f; do
  [ -f "$f" ] || continue
  matches_stack "$f" && staged+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#staged[@]}" -gt 0 ]; then
@STAGED_STAGES@
  :
fi

@TYPECHECK_STAGE@
exit 0
